generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid(7)) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String?
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
  profile Profile? 
  accounts OAuthAccount[]
  refreshTokens RefreshToken[]
}
model Profile{
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid(7)) @db.Uuid
  user      User     @relation(fields:[userId], references:[id], onDelete:Cascade)
  userId     Int  @unique
  nickname  String
  pictureId Int
  picture Asset @relation(fields:[pictureId], references:[id])
  createdAt DateTime @default(now())
  followedBy Profile[] @relation("UserFollows")
  following  Profile[] @relation("UserFollows")
  blocking     Profile[]        @relation("UserBlocks")
  blockedBy    Profile[]        @relation("UserBlocks")
  posts        Post[]
  reposts      Repost[]
  comments     Comment[]
  collections  Collection[]
  postLikes    PostLike[]
  commentLikes CommentLike[]
  collectionLikes CollectionLike[]
  messages  Message[]
  chatMember  ChatMember[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent Notification[] @relation("NotificationActor")
}

model Post {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @default(uuid(7)) @db.Uuid
  authorId      Int
  author        Profile     @relation(fields: [authorId], references: [id],onDelete: Cascade)
  description String?
  createdAt   DateTime @default(now())
  private     Boolean  @default(false)
  views       Int      @default(0)
  media        Media[] 
  comments     Comment[]
  likes        PostLike[]
  reposts      Repost[]
  collections   Collection[] 
  messages Message[]
  notifications Notification[]
  @@index([authorId, createdAt])
}

model Media {
  id           Int      @id @default(autoincrement())
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  cloudinaryId String   @unique                             
  cloudinaryAssetId      String   @unique                            
  resourceType String                                     
  format       String                                    
  url          String                                   
  thumbnail    String?
  width        Int?
  height       Int?
  bytes        Int                                     
  duration     Float?                                 
  createdAt    DateTime @default(now())
  postId      Int?
  post        Post? @relation(fields:[postId], references:[id], onDelete:Cascade)
  asset   Asset[] 
}
model Asset {
  id           Int      @id @default(autoincrement())
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  type     AssetType 
  media  Media? @relation(fields:[mediaId], references:[id], onDelete:SetNull)
  mediaId Int?
  profile Profile[]
}

enum AssetType {
  PROFILE_PICTURE
}

model Repost {
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  reposterId Int
  reposter   Profile @relation(fields: [reposterId], references: [id], onDelete:Cascade)
  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete:Cascade)
  createdAt DateTime @default(now())

  @@id([reposterId, postId])
  @@index([postId])
}

model Comment {
  id     Int           @id @default(autoincrement())
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  postId Int
  post   Post          @relation(fields: [postId], references: [id], onDelete:Cascade)
  authorId Int
  author   Profile          @relation(fields: [authorId], references: [id], onDelete:Cascade)
  text   String
  createdAt    DateTime @default(now())
  likes  CommentLike[]
  notifications Notification[]
  @@index([postId, createdAt])
}

model PostLike {
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete:Cascade)
  ownerId Int
  owner   Profile @relation(fields: [ownerId], references: [id], onDelete:Cascade)
  createdAt    DateTime @default(now())

  @@id([ownerId, postId])
  @@index([postId])
}

model CommentLike {
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete:Cascade)
  ownerId    Int
  owner      Profile    @relation(fields: [ownerId], references: [id], onDelete:Cascade)
  createdAt    DateTime @default(now())

  @@id([ownerId, commentId])
   @@index([commentId])
}

model Collection {
  id          Int     @id @default(autoincrement())
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  ownerId      Int
  owner        Profile    @relation(fields: [ownerId], references: [id], onDelete:Cascade)
  name        String
  description String
  active      Boolean @default(false)
  posts       Post[]
  messages Message[]
  likes  CollectionLike[]
  createdAt    DateTime @default(now())
  notifications Notification[]
}
model CollectionLike {
  publicId     String   @unique @default(uuid(7)) @db.Uuid   
  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete:Cascade)
  ownerId    Int
  owner      Profile    @relation(fields: [ownerId], references: [id], onDelete:Cascade)
  createdAt    DateTime @default(now())

  @@id([ownerId, collectionId])
  @@index([collectionId])
}

// Chat
model Chat {
  id          Int     @id @default(autoincrement())
  publicId          String        @unique @default(uuid(7)) @db.Uuid
  createdAt   DateTime      @default(now())
  members     ChatMember[]
  messages    Message[]
}

model ChatMember {
  id        Int     @id @default(autoincrement())
  publicId  String        @unique @default(uuid(7)) @db.Uuid
  chat      Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    Int        
  profile   Profile?          @relation(fields: [profileId], references: [id], onDelete: SetNull)
  profileId Int?        
  isArchived  Boolean  @default(false)
  @@unique([chatId, profileId])
}

model Message {
  id          Int     @id @default(autoincrement())
  publicId          String        @unique @default(uuid(7)) @db.Uuid
  chat      Chat            @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    Int          
  owner    Profile?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId  Int?          
  text   String?
  type      MessageType @default(TEXT)
  createdAt DateTime        @default(now())
  replyTo   Message?    @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replyToId Int?         
  replies   Message[]   @relation("MessageReplies")
  active Boolean @default(true)
  post Post? @relation(fields:[postId], references:[id])
  postId Int?
  collection Collection? @relation(fields:[collectionId], references:[id])
  collectionId Int?
  @@index([chatId,createdAt])
}

enum MessageType {
  TEXT
  POST
  COLLECTION
  EVENT
}
// Notifications
model Notification {
  id          Int              @id @default(autoincrement())
  publicId    String           @unique @default(uuid(7)) @db.Uuid
  recipientId Int
  recipient   Profile          @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     Int
  actor       Profile          @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  type        NotificationType
  postId      Int?
  post        Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   Int?
  comment     Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  collectionId      Int?
  collection        Collection?            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, read, createdAt])
}

enum NotificationType {
  LIKE_POST
  LIKE_COMMENT
  LIKE_COLLECTION
  COMMENT
  REPOST
  NEW_POST
  NEW_COLLECTION
  FOLLOW
}
//Auth
model OAuthAccount {
  id             Int      @id @default(autoincrement())
  publicId       String   @unique @default(uuid(7)) @db.Uuid
  provider       String                     
  providerUserId String                     
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
}
model RefreshToken {
  id         String    @id @default(uuid())
  familyId   String    
  userId     Int
  tokenHash  String
  used       Boolean   @default(false)
  revokedAt  DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@index([familyId])
}
